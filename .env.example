# Copy to .env.local and fill in. Never commit real values.

# =============================================================================
# REQUIRED: Supabase (auth, projects, compositions, render jobs)
# Get these from: https://app.supabase.com/project/_/settings/api
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# =============================================================================
# REQUIRED: Gemini (component analysis, agent pipeline, TTS voiceover)
# Get this from: https://aistudio.google.com/app/apikey
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key

# =============================================================================
# OPTIONAL: App URL
# Metadata/OG base URL. Falls back to the Vercel URL, then localhost.
# =============================================================================
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# =============================================================================
# OPTIONAL: Repo clone workspace
# Where cloned GitHub repos are written. Defaults to <os-tmp>/scenery-repos.
# In Docker/Fly this points at a mounted volume (/data/repos).
# =============================================================================
# REPOS_BASE_DIR=/data/repos

# =============================================================================
# OPTIONAL: Playwright worker (tier-1 preview rendering)
# Deploy playwright-worker/ as a separate app. Without it, previews fall
# through to the SSR and AI tiers.
# =============================================================================
# PLAYWRIGHT_WORKER_URL=https://your-playwright-worker.fly.dev
# PLAYWRIGHT_WORKER_SECRET=your_shared_secret_token

# =============================================================================
# OPTIONAL: Remotion Lambda (cloud video rendering)
# Only needed to render in the cloud instead of locally.
# Run `npm run deploy:remotion` to create the serve URL.
# Setup guide: https://remotion.dev/docs/lambda/setup
# =============================================================================
# REMOTION_AWS_REGION=us-east-1
# REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-function
# REMOTION_SERVE_URL=https://your-remotion-serve-url.com
# AWS credentials are read by the Remotion Lambda SDK from the standard
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (or REMOTION_AWS_*) variables.
# REMOTION_AWS_ACCESS_KEY_ID=your_aws_access_key_id
# REMOTION_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# =============================================================================
# playwright-worker/ only (set these on the worker app, not the Next.js app)
# =============================================================================
# WORKER_SECRET=your_shared_secret_token   # must match PLAYWRIGHT_WORKER_SECRET
# PORT=8080
# HOST=0.0.0.0

# =============================================================================
# SUPABASE SETUP NOTES
# =============================================================================
# 1. Enable GitHub OAuth in the Supabase Dashboard:
#    - Authentication > Providers > GitHub
#    - Client ID / Secret come from a GitHub OAuth App
#    - Callback URL: https://your-project.supabase.co/auth/v1/callback
#
# 2. Create the GitHub OAuth App at https://github.com/settings/developers
#    - Homepage URL: https://your-production-domain.com
#    - Callback URL: https://your-project.supabase.co/auth/v1/callback
#
# 3. Apply the SQL in supabase/migrations/ (Supabase SQL editor or `supabase db push`)
